{
  "theme": "palm",
  "name": "WireSocket",
  "description": "Real-time Yjs sync infrastructure for collaborative applications. Stateless, edge-deployed WebSocket servers with global routing, JWT auth, and zero vendor lock-in. You own the data.",
  "seo": {
    "metatags": {
      "canonical": "https://docs.wiresocket.com"
    },
    "indexing": "navigable"
  },
  "appearance": {
    "default": "dark"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": true
  },
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "decoration": "windows"
  },
  "interaction": {
    "drilldown": true
  },
  "metadata": {
    "timestamp": true
  },
  "colors": {
    "primary": "#0047AB",
    "light": "#0058BC",
    "dark": "#0047AB"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket-launch",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "security"
            ]
          },
          {
            "group": "Control Plane",
            "icon": "network-wired",
            "pages": [
              "control-plane/overview",
              "control-plane/onboarding",
              "control-plane/license-regions",
              "control-plane/app-setup",
              "control-plane/billing"
            ]
          },
          {
            "group": "Data Plane",
            "icon": "circle-nodes",
            "pages": [
              "data-plane/dataplane",
              "data-plane/editor-setup",
              "data-plane/document-lifecycle",
              "data-plane/regions",
              "data-plane/self-hosting"
            ]
          },
          {
            "group": "Internals",
            "icon": "gears",
            "pages": [
              "internals/plans-and-limits",
              "internals/error-reference",
              "internals/reliability",
              "internals/rate-limits"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/discovery",
              "api-reference/websocket",
              "api-reference/usage"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://wiresocket.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@wiresocket.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.wiresocket.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/wiresocket",
      "github": "https://github.com/WireSocket",
      "linkedin": "https://linkedin.com/company/wiresocket"
    }
  }
}